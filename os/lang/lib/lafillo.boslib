; lafillo.boslib - HTML to text for BOSL
; Include with: include "lib/lafillo.boslib" or -I lang lib/lafillo.boslib
;
; lafillo_print: (str --) pop string from stack, convert HTML to plain text, print.
; Usage: pushc "<html><body>Hello</body></html>"
;        call lafillo_print

lafillo_print:
    lafillop
    ret
